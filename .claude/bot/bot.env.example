# Template for .claude/bot/bot.env — copy this file to bot.env (gitignored) and
# fill in your GitHub App's identifiers. generate-gh-token.sh reads these to mint
# short-lived installation tokens.
#
# None of these are secrets on their own. The ONLY secret is the private key
# (BOT_PEM_FILE): keep it OUTSIDE the repo (e.g. ~/.claude/) and never commit it.
BOT_APP_ID=<your-github-app-id>
BOT_INSTALL_ID=<your-app-installation-id>
BOT_PEM_FILE="$HOME/.claude/<your-app-name>.pem"
